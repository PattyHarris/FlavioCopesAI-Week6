{
  "name": "port-pilot",
  "version": "0.1.0",
  "description": "Port Pilot is a CLI and TUI for managing listening ports on your machine.",
  "type": "module",
  "bin": {
    "ports": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsx src/index.tsx",
    "setup": "npm install && npm run build && npm link",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "cli",
    "ports",
    "terminal",
    "ink",
    "developer-tools"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "chalk": "^5.3.0",
    "commander": "^12.1.0",
    "execa": "^9.3.0",
    "ink": "^5.0.1",
    "react": "^18.3.1"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "@types/react": "^18.3.3",
    "tsup": "^8.2.4",
    "tsx": "^4.16.2",
    "typescript": "^5.5.4"
  }
}
